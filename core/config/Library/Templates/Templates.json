  "koreanFieldwork": {
    "author": "DAI / Korean fieldwork adaptation",
    "configuration": {
      "forms": {
        "Project:default": {
          "hidden": [],
          "fields": {
            "projectInvestigationMode": {
              "inputType": "dropdown",
              "constraintIndexed": true
            },
            "projectBoundarySetupState": {
              "inputType": "dropdown",
              "constraintIndexed": true
            },
            "projectBoundarySummary": {
              "inputType": "text",
              "constraintIndexed": true
            }
          },
          "valuelists": {
            "projectInvestigationMode": "KoreanFieldwork-projectInvestigationMode",
            "projectBoundarySetupState": "KoreanFieldwork-projectBoundarySetupState"
          }
        },
        "Operation:default": {
          "hidden": [],
          "fields": {}
        },
        "Trench:default": {
          "hidden": [],
          "fields": {
            "isRecordedIn": {
              "inputType": "relation",
              "range": ["Operation"]
            },
            "liesWithin": {
              "inputType": "relation",
              "range": ["Operation"]
            },
            "recordCreationTiming": {
              "inputType": "dropdown",
              "constraintIndexed": true
            },
            "fieldRecordQuality": {
              "inputType": "checkboxes",
              "constraintIndexed": true
            },
            "verificationState": {
              "inputType": "dropdown",
              "constraintIndexed": true
            },
            "featureInvestigationChecklist": {
              "inputType": "checkboxes",
              "constraintIndexed": true
            },
            "longAxisOrientation": {
              "inputType": "input",
              "constraintIndexed": true
            },
            "shortAxisOrientation": {
              "inputType": "input",
              "constraintIndexed": true
            },
            "orientationReference": {
              "inputType": "input",
              "constraintIndexed": true
            },
            "orientationNote": {
              "inputType": "text",
              "constraintIndexed": true
            }
          },
          "valuelists": {
            "recordCreationTiming": "KoreanFieldwork-recordCreationTiming",
            "fieldRecordQuality": "KoreanFieldwork-fieldRecordQuality",
            "verificationState": "KoreanFieldwork-verificationState",
            "featureInvestigationChecklist": "KoreanFieldwork-featureInvestigationChecklist"
          },
          "groups": [
            {
              "name": "stem",
              "fields": [
                "identifier",
                "category",
                "shortDescription",
                "processor",
                "campaign",
                "date"
              ]
            },
            {
              "name": "hierarchy",
              "fields": ["hasChildren", "isRecordedIn", "liesWithin"]
            },
            {
              "name": "workflow",
              "fields": ["isSubjectOf", "isResultOf"]
            },
            {
              "name": "properties",
              "fields": ["description"]
            },
            {
              "name": "koreanFieldwork",
              "fields": [
                "featureInvestigationChecklist",
                "recordCreationTiming",
                "fieldRecordQuality",
                "verificationState"
              ]
            },
            {
              "name": "dimension",
              "fields": ["area", "dimensionLength", "dimensionWidth"]
            },
            {
              "name": "position",
              "fields": [
                "geometry",
                "spatialLocation",
                "longAxisOrientation",
                "shortAxisOrientation",
                "orientationReference",
                "orientationNote"
              ]
            }
          ]
        },
        "DailyLog": {
          "parent": "Operation",
          "hidden": [],
          "fields": {
            "isRecordedIn": {
              "inputType": "relation",
              "range": ["Operation"]
